# Required: canonical HTTPS origin of your Nextcloud server
NEXTCLOUD_TALK_BASE_URL=https://nc.example.com

# Required: create a unique random secret locally, then use the same value when installing the Talk bot.
# Never commit the real value.
NEXTCLOUD_TALK_BOT_SECRET=replace-with-a-random-secret-at-least-40-characters

# Required: Hermes profile to run. This integration invokes it via `hermes -p <profile>`.
HERMES_PROFILE=frank

# Required in normal operation: comma-separated stable Nextcloud Talk IDs/tokens.
NEXTCLOUD_TALK_ALLOWED_USERS=users/alice
NEXTCLOUD_TALK_ALLOWED_ROOMS=your-talk-room-token

# Optional. Defaults are safe: loopback only and mention required.
NEXTCLOUD_TALK_MENTION_ALIASES=@frank
NEXTCLOUD_TALK_REQUIRE_MENTION=true
NEXTCLOUD_TALK_LISTEN_HOST=127.0.0.1
NEXTCLOUD_TALK_LISTEN_PORT=8790
